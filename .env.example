# --- SelfHost Media Orchestrator Configuration ---

# 1. API Keys (Optional if set via UI)
TMDB_API_KEY=your_tmdb_key_here
OMDB_API_KEY=your_omdb_key_here

# 2. Universal Drive Mapping (Local Machine Paths)
# Update these to the actual paths on your host computer.
# Examples: 
# Windows: DRIVE_D_PATH=D:\
# Linux:   DRIVE_D_PATH=/mnt/storage
DRIVE_D_PATH=
DRIVE_E_PATH=
DRIVE_F_PATH=

# 3. Network Proxy (Optional)
# HTTP_PROXY=http://your-proxy-ip:port
# HTTPS_PROXY=http://your-proxy-ip:port
